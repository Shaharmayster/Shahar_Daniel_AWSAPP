# Copy this file to terraform.tfvars and adjust values as needed.
# terraform.tfvars is gitignored — do not commit secrets or account-specific values.

aws_region   = "us-east-1"
project_name = "grandma-greeting"
environment  = "production"

vpc_cidr            = "10.0.0.0/16"
public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]

instance_type = "t3.micro"
app_port      = 5000

asg_min_size         = 2
asg_desired_capacity = 2
asg_max_size         = 2

# Leave empty to use the latest Amazon Linux 2023 AMI in the selected region.
# ami_id = ""
